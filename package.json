{
  "name": "eslint-plugin-detachhead",
  "version": "1.3.1",
  "description": "detachhead's eslint rules",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "detachhead",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "lint": "npm-run-all \"lint:*\"",
    "lint:eslint-docs": "npm-run-all \"update:eslint-docs -- --check\"",
    "lint:check": "npm run build && eslint .",
    "lint:fix": "npm run lint:check -- --fix",
    "build": "rimraf ./dist && tsc -p src/tsconfig.json",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "tsc && ts-mocha -p tsconfig.json tests/**/*.ts --timeout 10000",
    "check": "npm run lint:check && npm run lint:eslint-docs && npm run format:check && npm run test",
    "update:eslint-docs": "npm run build && eslint-doc-generator"
  },
  "dependencies": {
    "@typescript-eslint/parser": ">=5.53.0",
    "@typescript-eslint/utils": ">=5.53.0",
    "eslint": "^9",
    "throw-expression": "^1.0.2",
    "tsutils": "^3.21.0"
  },
  "devDependencies": {
    "@detachhead/eslint-config": "1.5.4-5b5d4e0d1e206c4c2d3a635a4128eaa2ca571141",
    "@detachhead/ts-helpers": "^15.0.0",
    "@dprint/formatter": "^0.5.1",
    "@dprint/json": "^0.21.3",
    "@dprint/markdown": "^0.22.1",
    "@dprint/typescript": "^0.96.1",
    "@types/eslint": ">=9",
    "@types/node": "^16.10.5",
    "dprint": "^0.54.0",
    "dprint-plugin-yaml": "^0.6.0",
    "eslint-doc-generator": ">=3",
    "eslint-plugin-eslint-plugin": ">=5.0.0",
    "mocha": "^10.0.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^3.0.2",
    "ts-mocha": "^10.0.0"
  },
  "engines": {
    "node": "^14.17.0 || ^16.0.0 || >= 18.0.0"
  },
  "peerDependencies": {
    "eslint": "^9",
    "typescript": ">=5.1.3"
  },
  "license": "ISC"
}
